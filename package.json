{
  "name": "praetor",
  "version": "0.0.1",
  "private": true,
  "description": "Praetor — the mission runtime for autonomous agents. Charter-driven, fiscally gated, audit-logged by default. Native design, video, scraping, knowledge, GEO/SEO, EU AI Act.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "tsc -b",
    "praetor": "node packages/cli/dist/index.js",
    "dev": "npm run dev --workspace=@praetor/dashboard"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "protobufjs": "^7.5.5",
    "esbuild": "^0.25.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnemopay/praetor.git"
  }
}
