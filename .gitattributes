# Stop the LF/CRLF churn that turns every Windows commit into noise.
* text=auto eol=lf

*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.xml       text eol=lf

*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.mp4       binary
*.webm      binary
*.mp3       binary
*.wav       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.exe       binary
*.dll       binary
*.so        binary
*.wasm      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.sqlite    binary
*.sqlite3   binary
