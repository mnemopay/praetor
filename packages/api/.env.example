# ─── Required ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8788
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Optional ───────────────────────────────────────────────────────────────
PRAETOR_REPO_ROOT=../../
DEFAULT_MISSION_BUDGET_USD=5
# Comma-separated list of allowed dashboard origins. Localhost is always allowed.
# ALLOWED_ORIGINS=https://praetor.dev,https://app.praetor.dev

# ─── Praetor runtime keys (forwarded to spawned `praetor run` subprocesses) ─
# LLM providers (any one is enough; the runtime falls back to EchoAgent if none set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# MnemoPay fiscal gate (for live HITL)
MNEMOPAY_API_KEY=
MNEMOPAY_BASE_URL=https://api.mnemopay.com

# Business-ops (CLI tools: send_email, issue_invoice, schedule_meeting, upsert_contact)
MAILEROO_API_KEY=
STRIPE_SECRET_KEY=
CALCOM_API_KEY=

# UGC pipeline
LUMA_API_KEY=
REPLICATE_API_TOKEN=
HEDRA_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Scrape (Firecrawl is the paid tier; default uses fetch + Playwright fallback)
FIRECRAWL_API_KEY=

# Social
X_API_KEY=
TIKTOK_API_KEY=

# ─── World-gen (3D models + gaussian-splat worlds) ───────────────────────
# Set WORLD_GEN_REQUIRE_LIVE=true to refuse the mock backend and force a live
# provider. Pick at least one model backend and (optionally) one world backend.
WORLD_GEN_REQUIRE_LIVE=false
# Selector mode: "quality" (default) prefers the highest-fidelity backend
# that has credentials. "cost" prefers the cheapest path: free self-host
# first, then free credits, then the paid backends in ascending price.
WORLD_GEN_PREFER=quality
# Where publish_3d_scene writes viewer HTML. Defaults to <repoRoot>/praetor-out/scenes
# WORLD_GEN_OUT_DIR=

# TRELLIS-2 (Microsoft) via Replicate or self-hosted
TRELLIS2_REPLICATE_MODEL=firtoz/trellis
TRELLIS2_ENDPOINT=
TRELLIS2_AUTH=

# Hunyuan3D 2.1 (Tencent) via Replicate or self-hosted
HUNYUAN3D_REPLICATE_MODEL=tencent/hunyuan3d-2
HUNYUAN3D_ENDPOINT=
HUNYUAN3D_AUTH=

# Tripo AI — https://www.tripo3d.ai/api
TRIPO_API_KEY=
TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi

# fal.ai sam-3 image-to-3D — https://fal.ai/models/fal-ai/sam-3/3d-objects
FAL_API_KEY=
FAL_MODEL=fal-ai/sam-3/3d-objects

# World Labs Marble (gaussian-splat worlds)
WORLDLABS_API_KEY=
WORLDLABS_BASE_URL=https://api.worldlabs.ai/v1

# Tencent HY-World 2.0 (self-hosted only — no managed API yet)
HYWORLD_ENDPOINT=
HYWORLD_AUTH=
