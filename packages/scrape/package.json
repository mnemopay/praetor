{
  "name": "@praetor/scrape",
  "version": "0.2.0",
  "description": "Praetor scrape pack — native HTTP client (no third-party fetch lib), JSON-LD extractor, sitemap walker, X.com syndication endpoint, robots-aware. Crawl4AI / Playwright / Firecrawl are optional opt-in adapters.",
  "keywords": [
    "scrape",
    "crawl",
    "json-ld",
    "sitemap",
    "x.com",
    "praetor"
  ],
  "homepage": "https://praetor.mnemopay.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnemopay/praetor.git",
    "directory": "packages/scrape"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "J&B Enterprise LLC <jeremiah@getbizsuite.com>"
}
