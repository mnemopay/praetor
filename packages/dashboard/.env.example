VITE_API_BASE_URL=http://127.0.0.1:8788

# ── PRODUCTION AUTH ─────────────────────────────────────────────────────────
# Real Supabase auth. The API server must run with matching SUPABASE_URL +
# SUPABASE_SERVICE_ROLE_KEY so it can verify tokens minted in the browser.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── LOCAL DEV BYPASS ────────────────────────────────────────────────────────
# When the two Supabase variables above are unset, set this to "1" to enable
# the in-memory dev-user shim. The API server MUST run with PRAETOR_DEV_MODE=1
# under the same flag — production should never set either of them.
# VITE_PRAETOR_DEV_MODE=1
