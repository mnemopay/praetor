{
  "name": "@praetor/cli",
  "version": "0.1.0",
  "description": "Praetor — the agent runtime CLI. Run YAML mission charters with native browser, sandbox, voice, screen, scrape, and payment tools wired in. EU AI Act Article 12 audit bundles, MnemoPay fiscal gating, prompt caching, governance defaults.",
  "keywords": [
    "agent",
    "ai",
    "runtime",
    "charter",
    "browser-agent",
    "sandbox",
    "tts",
    "praetor",
    "mnemopay",
    "audit"
  ],
  "homepage": "https://github.com/mnemopay/praetor#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "praetor": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@praetor/api": "*",
    "@praetor/core": "*",
    "@praetor/payments": "*",
    "@praetor/agents": "*",
    "@praetor/coding-agent": "*",
    "@praetor/scrape": "*",
    "@praetor/knowledge": "*",
    "@praetor/router": "*",
    "@praetor/business-ops": "*",
    "@praetor/design": "*",
    "@praetor/seo": "*",
    "@praetor/tools": "*",
    "@praetor/sysadmin": "*",
    "@praetor/game-assets": "*",
    "@praetor/sandbox": "*",
    "@praetor/vision": "*",
    "@praetor/voice": "*",
    "@praetor/browser": "*",
    "@praetor/social": "*",
    "@praetor/world-gen": "*",
    "yaml": "^2.5.0"
  },
  "author": "Jeremiah Omiagbo <jeremiah@getbizsuite.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnemopay/praetor.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
